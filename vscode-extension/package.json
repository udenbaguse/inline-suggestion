{
  "name": "inline-suggestion-local-dev",
  "displayName": "Inline Suggestion (Local AI)",
  "description": "VS Code offline inline suggestions using local Transformers model.",
  "version": "0.2.0",
  "publisher": "local-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/udenbaguse/inline-suggestion"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "commands": [
      {
        "command": "inlineSuggestionLocalDev.installModel",
        "title": "Inline Suggestion: Install Model"
      },
      {
        "command": "inlineSuggestionLocalDev.killModel",
        "title": "Inline Suggestion: Kill Model"
      },
      {
        "command": "inlineSuggestionLocalDev.debugSuggest",
        "title": "Inline Suggestion: Debug Current Cursor"
      }
    ],
    "configuration": {
      "title": "Inline Suggestion (Local AI)",
      "properties": {}
    },
    "keybindings": [
      {
        "key": "tab",
        "command": "editor.action.inlineSuggest.commit",
        "when": "inlineSuggestionVisible && textInputFocus && !editorReadonly"
      }
    ]
  },
  "scripts": {
    "test": "echo \"No tests\""
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "is-online": "^9.0.1"
  }
}
